deck START 0    # 0 is midnight new year
deck STOP 8760*3 # 8760 is one year
deck dtSim 5/60
deck nIteTrnsys 50
deck nWarnTrnsys 10000000 # [-]
deck nCallTraceTrnys 1000

############# AUTOMATIC WORK BOOL ##############################

bool doAutoUnitNumbering True
